generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model SystemUser {
  id         String   @id @default(uuid())
  name       String
  username   String   @unique
  password   String
  role       String   @default("Admin")
  department String?
  createdAt  DateTime @default(now())
}

model Board {
  id          String        @id @default(uuid())
  name        String
  description String?
  color       String        @default("#6366f1")
  team        String[]      @default([]) // Array of initials
  columns     BoardColumn[]
  users       BoardUser[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

model BoardColumn {
  id      String      @id @default(uuid())
  title   String
  color   String      @default("#6b7280")
  order   Int         @default(0)
  boardId String
  board   Board       @relation(fields: [boardId], references: [id], onDelete: Cascade)
  tasks   BoardTask[]
}

model BoardTask {
  id          String      @id @default(uuid())
  title       String
  description String?
  priority    String      @default("Medium")
  tag       String?
  tagColor  String?
  assignee  String?
  startDate String?
  endDate   String?
  link      String?
  order     Int         @default(0)
  columnId  String
  column    BoardColumn @relation(fields: [columnId], references: [id], onDelete: Cascade)
  todos     TaskTodo[]
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
}

model TaskTodo {
  id     String    @id @default(uuid())
  text   String
  done   Boolean   @default(false)
  link   String?
  taskId String
  task   BoardTask @relation(fields: [taskId], references: [id], onDelete: Cascade)
}

model BoardUser {
  id       String @id @default(uuid())
  name     String
  email    String
  password String
  role     String @default("Employee")
  initials String
  boardId  String
  board    Board  @relation(fields: [boardId], references: [id], onDelete: Cascade)

  @@unique([email, boardId])
}
